# CLIFTON MANAGED
Host jump.*.aip1.isambard
	Hostname ai.login.isambard.ac.uk
	IdentityFile "~/.ssh/id_ed25519"
Host *.aip1.isambard !jump.*.aip1.isambard
	Hostname ai-p1.access.isambard.ac.uk
	ProxyJump %r@jump.%n
	IdentityFile "~/.ssh/id_ed25519"
	AddKeysToAgent yes

